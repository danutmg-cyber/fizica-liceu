    function showPageFromHash() {
      const match = window.location.hash.match(/pagina-(\d+)/);
      let pageNumber = match ? Number(match[1]) : 1;

      if (!Number.isInteger(pageNumber) || pageNumber < 1 || pageNumber > pages.length) {
        pageNumber = 1;
        window.location.hash = '#pagina-1';
        return;
      }

      pages.forEach((page, index) => {
        page.hidden = index !== pageNumber - 1;
      });

      window.scrollTo({ top: 0, behavior: 'auto' });

      if (window.MathJax && window.MathJax.typesetPromise) {
        window.MathJax.typesetPromise();
      }
    }

    window.addEventListener('hashchange', showPageFromHash);
